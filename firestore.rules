// Rektör Oldum — Firestore Security Rules
//
// Deploy: Firebase Console → Firestore Database → Rules → bu içeriği yapıştır → Yayınla
// Veya CLI: firebase deploy --only firestore:rules
//
// Korumalar (R-Fatih önerisi v0.4.27 + serhattural raporu):
//  1) Yalnızca anonim auth ile yazılabilir
//  2) Doc ID = request.auth.uid (kullanıcı başına TEK kayıt)
//  3) Update yalnızca yeni skor mevcuttan yüksekse (server-side karşılaştırma)
//  4) Score 0..5000, year 1..200, prestige 0..100, rank 1..1000 aralığında
//     (5 May 2026: max 100000 -> 5000, sahte yuksek skor saldirisi sonrasi)
//     (6 May 2026: prestige -100..200 -> 0..100, oyun motoru MAX_PRESTIGE=100 ile eşitlendi)
//  5) Name 1-30 karakter string
//  6) Read herkese açık (skor tablosu publik)
//  7) Delete kapalı

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /scores/{scoreId} {

      // Skor tablosu okuması herkese açık
      allow read: if true;

      // Ortak alan + tip + aralık doğrulamaları (create + update için)
      function validScore(data, uid) {
        return data.keys().hasOnly(
                ['uid', 'gameId', 'name', 'score', 'year', 'rank', 'prestige', 'createdAt'])
            && data.keys().hasAll(
                ['uid', 'gameId', 'name', 'score', 'year', 'rank', 'prestige', 'createdAt'])
            && data.uid == uid
            && data.gameId is string
            && data.gameId.size() >= 1
            && data.gameId.size() <= 100
            && data.name is string
            && data.name.size() >= 1
            && data.name.size() <= 30
            && data.score is int
            && data.score >= 0
            && data.score <= 5000
            && data.year is int
            && data.year >= 1
            && data.year <= 200
            && data.rank is int
            && data.rank >= 1
            && data.rank <= 1000
            && data.prestige is int
            && data.prestige >= 0
            && data.prestige <= 100
            && data.createdAt == request.time;
      }

      // Yeni kayıt oluşturma: doc ID = uid, ilk kayıt
      allow create: if
        request.auth != null
        && scoreId == request.auth.uid
        && validScore(request.resource.data, request.auth.uid);

      // Mevcut kaydı güncelleme: yeni skor MEVCUT skordan yüksek olmalı
      // (R-Fatih önerisi — kullanıcı başına yalnızca en iyi skor tutulur)
      allow update: if
        request.auth != null
        && scoreId == request.auth.uid
        && validScore(request.resource.data, request.auth.uid)
        && request.resource.data.score > resource.data.score;

      // Silme yasak
      allow delete: if false;
    }
  }
}
